generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Article {
  id          Int             @id @default(autoincrement())
  slug        String          @unique
  title       String
  summary     String?         @db.Text
  content     String?         @db.LongText
  imageUrl    String?
  category    ArticleCategory
  author      String?
  views       Int             @default(0)
  publishedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("articles")
}

model Pronostic {
  id         Int      @id @default(autoincrement())
  fixtureId  Int
  homeTeam   String
  awayTeam   String
  prediction String
  result     String?
  confidence Int      @default(50)
  league     String
  matchDate  DateTime
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@map("pronostics")
}

model User {
  id         Int         @id @default(autoincrement())
  email      String      @unique
  password   String
  role       Role        @default(ADMIN)
  pronostics Pronostic[]
  createdAt  DateTime    @default(now())

  @@map("users")
}

enum ArticleCategory {
  TRANSFERT
  ACTU
  ANALYSE
  INTERVIEW
  RESULTATS
}

enum Role {
  ADMIN
  USER
}
