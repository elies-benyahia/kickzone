# =============================================
# WARZONE / CDL ESPORT — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# =============================================

# --- Base de données ---
DATABASE_URL="mysql://user:password@localhost:3306/warzone_cdl"
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=warzone_cdl
MYSQL_USER=user
MYSQL_PASSWORD=password

# --- JWT ---
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d

# --- Serveur ---
PORT=3001
NODE_ENV=development

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Scraping ---
SCRAPE_INTERVAL_MINUTES=60
SCRAPE_ENABLED=true

# --- Admin initial (seed) ---
ADMIN_EMAIL=admin@warzone-cdl.fr
ADMIN_PASSWORD=ChangeMe2024!

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_LOGIN=5
